generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Service {
  id               String   @id @default(uuid())
  organiser_id     String
  name             String
  duration_minutes Int
  working_hours    Json
  total_capacity   Int      @default(1)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  slots            Slot[]
}

model Slot {
  id                 String   @id @default(uuid())
  service_id         String
  date               DateTime
  start_time         DateTime
  end_time           DateTime
  available_capacity Int
  total_capacity     Int
  status             String   @default("available")
  
  service            Service  @relation(fields: [service_id], references: [id])
  bookings           Booking[]

  @@unique([service_id, date, start_time])
}

model Booking {
  booking_id     String   @id @default(uuid())
  user_id        String
  service_id     String
  slot_id        String
  date           String
  status         String
  payment_status String   @default("pending")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  slot           Slot     @relation(fields: [slot_id], references: [id])
}
